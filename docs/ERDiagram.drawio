        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;erDiagram\n\nUSER ||--o{ APPOINTMENT : books\nDOCTOR ||--o{ APPOINTMENT : attends\nHOSPITAL ||--o{ DOCTOR : has\nDOCTOR ||--o{ AVAILABILITY : provides\n\nAPPOINTMENT ||--|| PAYMENT : has\nAPPOINTMENT ||--|| PATIENT_DETAILS : contains\nAPPOINTMENT ||--o{ CHAT : includes\nAPPOINTMENT ||--|| FEEDBACK : receives\nAPPOINTMENT ||--o{ REMINDER : generates\n\nUSER ||--o{ FAMILY_MEMBER : manages\nUSER ||--o{ SUPPORT_TICKET : raises\n\nUSER {\nint id PK\nstring name\nstring mobile\nstring email\n}\n\nDOCTOR {\nint id PK\nstring name\nstring specialization\nint hospital_id FK\n}\n\nHOSPITAL {\nint id PK\nstring name\nstring address\n}\n\nAVAILABILITY {\nint id PK\nint doctor_id FK\ndate day\ntime start_time\ntime end_time\n}\n\nAPPOINTMENT {\nint id PK\nint patient_id FK\nint doctor_id FK\ndate appointment_date\ntime appointment_time\nstring status\nstring consultation_type\n}\n\nPATIENT_DETAILS {\nint id PK\nint appointment_id FK\nint age\nfloat weight\nstring complaint\n}\n\nPAYMENT {\nint id PK\nint appointment_id FK\ndecimal amount\nstring payment_status\n}\n\nFEEDBACK {\nint id PK\nint appointment_id FK\nint doctor_rating\nint clinic_rating\n}\n\nCHAT {\nint id PK\nint appointment_id FK\nstring sender\nstring message\n}\n\nREMINDER {\nint id PK\nint appointment_id FK\nstring message\n}\n\nSUPPORT_TICKET {\nint id PK\nint user_id FK\nstring status\n}\n\nFAMILY_MEMBER {\nint id PK\nint user_id FK\nstring relation\nstring name\n}&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="Z6ydOvlge-8gYV2KpOnU-1">
