        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;classDiagram\n\nclass User {\n    +int userId\n    +String name\n    +double walletBalance\n}\n\nclass Sale {\n    +int saleId\n    +String brand\n    +double earning\n    +String status\n    +boolean advancePaid\n}\n\nclass Wallet {\n    +int walletId\n    +double balance\n    +credit(amount)\n    +debit(amount)\n}\n\nclass Payout {\n    +int payoutId\n    +double amount\n    +String type\n    +String status\n}\n\nclass Withdrawal {\n    +int withdrawalId\n    +double amount\n    +Date createdAt\n    +String status\n}\n\nclass Transaction {\n    +int transactionId\n    +double amount\n    +String type\n    +String status\n}\n\nclass PayoutService {\n    +calculateAdvancePayout()\n    +calculateFinalPayout()\n}\n\nclass ReconciliationService {\n    +approveSale()\n    +rejectSale()\n}\n\nclass WithdrawalService {\n    +withdraw()\n    +validate24HourRule()\n}\n\nclass RecoveryService {\n    +recoverFailedPayout()\n}\n\nUser \&quot;1\&quot; --&gt; \&quot;*\&quot; Sale : owns\nUser \&quot;1\&quot; --&gt; \&quot;1\&quot; Wallet : has\nUser \&quot;1\&quot; --&gt; \&quot;*\&quot; Withdrawal : requests\n\nSale \&quot;1\&quot; --&gt; \&quot;0..1\&quot; Payout : generates\nWallet \&quot;1\&quot; --&gt; \&quot;*\&quot; Transaction : records\nWithdrawal \&quot;1\&quot; --&gt; \&quot;1\&quot; Transaction : creates\n\nPayoutService --&gt; Sale\nPayoutService --&gt; Payout\n\nReconciliationService --&gt; Sale\nReconciliationService --&gt; Payout\n\nWithdrawalService --&gt; Wallet\nWithdrawalService --&gt; Withdrawal\n\nRecoveryService --&gt; Wallet\nRecoveryService --&gt; Transaction&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="fq_wQzyx7iv_KexWPjWe-192">
